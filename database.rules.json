{
  "rules": {
    ".read": false,
    ".write": false,

    "players": {
      "$uid": {
        ".read": "auth !== null",
        ".write": "auth !== null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name', 'createdAt']) && newData.child('name').isString() && newData.child('name').val().length <= 16 && newData.child('createdAt').isNumber()"
      }
    },

    "nameclaims": {
      "$nameKey": {
        ".read": "auth !== null",
        ".write": "auth !== null",
        ".validate": "newData.hasChildren(['uid', 'pinHash']) && newData.child('uid').isString() && newData.child('pinHash').isString() && $nameKey.length >= 1 && $nameKey.length <= 20"
      }
    },

    "leaderboard": {
      ".read": "auth !== null",
      "$gen": {
        ".validate": "$gen === 'gen1' || $gen === 'gen2'",
        "$mode": {
          ".validate": "$mode === 'single' || $mode === 'victoryroad' || $mode === 'safari'",
          "$entryId": {
            ".write": "auth !== null && (!data.exists() || data.child('uid').val() === auth.uid)",
            ".validate": "newData.hasChildren(['uid', 'name', 'score', 'at']) && newData.child('uid').val() === auth.uid && newData.child('name').isString() && newData.child('name').val().length <= 16 && newData.child('score').isNumber() && newData.child('score').val() >= 0 && newData.child('score').val() <= 10000 && newData.child('at').isNumber()"
          }
        }
      }
    },

    "rooms": {
      "$code": {
        ".read": "auth !== null",
        ".write": "auth !== null",
        ".validate": "$code.length === 6"
      }
    },

    "draft": {
      "throne": {
        "$tier": {
          ".read": "auth !== null",
          ".write": "auth !== null",
          ".validate": "($tier === 'day' || $tier === 'week' || $tier === 'month' || $tier === 'year' || $tier === 'all') && newData.hasChildren(['holderUid', 'holderName', 'takenAt'])"
        }
      },
      "thronehistory": {
        "$tier": {
          ".read": "auth !== null",
          "$entry": {
            ".write": "auth !== null && !data.exists()",
            ".validate": "($tier === 'day' || $tier === 'week' || $tier === 'month' || $tier === 'year' || $tier === 'all') && newData.hasChildren(['name', 'at']) && newData.child('name').isString() && newData.child('name').val().length <= 16 && newData.child('at').isNumber()"
          }
        }
      },
      "daily": {
        "$dateCT": {
          "seed": {
            ".read": "auth !== null",
            ".write": false
          },
          "entries": {
            "$uid": {
              ".read": "auth !== null",
              ".write": "auth !== null && auth.uid === $uid && !data.exists()",
              ".validate": "newData.hasChildren(['name', 'at']) && newData.child('name').isString() && newData.child('name').val().length <= 16 && newData.child('at').isNumber()"
            }
          }
        }
      }
    }
  }
}
